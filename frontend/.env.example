# Local frontend environment variables for development
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY is also supported for compatibility
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only key used by Next API routes for provisioning users and profiles.
# Prefer this name in .env.local. Do not expose it in client bundles.
SUPABASE_SERVICE_ROLE_KEY=
# Optional: when set, signup can promote this account to super admin in custom provisioning flows.
SUPER_ADMIN_EMAIL=
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000   
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PORTAL_URL=http://localhost:3000/portal
